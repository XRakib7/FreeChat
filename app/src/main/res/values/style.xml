<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Message bubble backgrounds -->
    <style name="BubbleSent">
        <item name="android:background">@color/bubble_sent</item>
        <item name="android:padding">8dp</item>
        <item name="android:elevation">2dp</item>
    </style>

    <style name="BubbleReceived">
        <item name="android:background">@color/bubble_received</item>
        <item name="android:padding">8dp</item>
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Input fields -->
    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/teal_700</item>
    </style>
</resources>