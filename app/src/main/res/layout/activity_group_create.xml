<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/teal_700" app:titleTextColor="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <EditText android:id="@+id/etGroupName"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Group name"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Add members (phone numbers, one per line or comma-separated):"
                android:textSize="13sp"/>

            <EditText android:id="@+id/etPhones"
                android:layout_width="match_parent" android:layout_height="120dp"
                android:hint="+12025551234&#10;+447700900123"
                android:inputType="textMultiLine"
                android:gravity="top"/>

            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone"/>

            <Button android:id="@+id/btnCreate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Create Group"
                android:backgroundTint="@color/teal_700"/>
        </LinearLayout>
    </ScrollView>

</LinearLayout>