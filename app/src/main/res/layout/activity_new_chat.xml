<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
            android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
            android:background="@color/teal_700" app:titleTextColor="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <EditText android:id="@+id/etSearch"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Search by phone number (e.g. +12025551234)"
        android:inputType="phone" android:padding="16dp"/>

    <ProgressBar android:id="@+id/progressBar"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerViewResults"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

</LinearLayout>